# Supabase — required for employee roster and slip history persistence
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Alternative key name (either ANON_KEY or PUBLISHABLE_KEY is accepted):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Server-only secret (service role). Required for payroll admin checks, Authorised Slip
# signature/seal uploads, and signed URLs. NEVER prefix with NEXT_PUBLIC.
# Production fails closed if this is absent.
SUPABASE_SECRET_KEY=your-service-role-or-secret-key

# Canonical application URL — REQUIRED for QR codes and verification links.
# Prefer your custom domain when ready (e.g. https://pay.yourcompany.com).
# Git-branch preview URLs (*-git-*.vercel.app) are always rejected.
# Production fails closed if this is unset.
NEXT_PUBLIC_APP_URL=https://portfolix-internal-payslip-generato.vercel.app
