# Supabase — required for employee roster and slip history persistence
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Alternative key name (either ANON_KEY or PUBLISHABLE_KEY is accepted):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Server-only secret (service role). Required for Authorised Slip signature/seal
# uploads and signed URLs. NEVER prefix with NEXT_PUBLIC. Fail closed if absent.
SUPABASE_SECRET_KEY=your-service-role-or-secret-key
